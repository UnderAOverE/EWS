# =====================================================================================================
# Project-local runtime artefacts
# =====================================================================================================
# Logs land under var/logs/ (gitignored via `var/` above) but catch the loose case too.
logs/
*.log

# Mongo dumps / fixtures
dumps/
*.bson

# Sample email previews / generated outputs.
output/


# =====================================================================================================
# Agent-local-only working notes - kept on disk, not tracked.
# =====================================================================================================
.claude/
CLAUDE.md
SKILL.md
CHANGELOG.md


# =====================================================================================================
# Secret-bearing env files - every file under conf/secrets/ is ignored EXCEPT *.example templates.
# Developer copies the template, fills in real values, and the local copy stays out of the repo.
# =====================================================================================================
conf/secrets/*
!conf/secrets/*.example


# =====================================================================================================
# Archived previous tree - kept on disk for reference, not tracked. Adds to .gitignore only stop NEW
# files from being staged; the archive snapshot already in git history is preserved.
# =====================================================================================================
v2/
